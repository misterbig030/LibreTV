{
  "rewrites": [
    {
      "source": "/proxy/:path*",
      "destination": "/api/proxy/:path*"
    },
    {
      "source": "/",
      "destination": "/api/page"
    },
    {
      "source": "/index.html",
      "destination": "/api/page"
    },
    {
      "source": "/s=:query",
      "destination": "/api/page"
    },
    {
      "source": "/player.html",
      "destination": "/api/page"
    },
    {
      "source": "/player.html/:path*",
      "destination": "/api/page"
    },
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ]
}
